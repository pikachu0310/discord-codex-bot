# Discord Botのトークン
# Discord Developer Portalで取得: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# 作業ディレクトリのベースパス
# リポジトリのクローン、ログ、セッション情報などが保存される場所
WORK_BASE_DIR=~/codex-bot-work

# Codex実行時に追加するシステムプロンプト（オプション）
# Codexの動作をカスタマイズしたい場合に使用
# CODEX_APPEND_SYSTEM_PROMPT="あなたは日本語で応答します"

# Codex CLIの最大出力トークン数（オプション）
# 設定しない場合はデフォルト値（25,000）が使用されます
# CODEX_CODE_MAX_OUTPUT_TOKENS=25000

# Google Gemini APIキー（スレッド名生成用・オプション）
# GEMINI_API_KEY=your_gemini_api_key

# PLaMo-2-translate API URL（翻訳機能・オプション）
# PLAMO_TRANSLATOR_URL=http://localhost:8080
