# Discord Botのトークン
# Discord Developer Portalで取得: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# 作業ディレクトリのベースパス
# リポジトリのクローン、ログ、セッション情報などが保存される場所
WORK_BASE_DIR=~/codex-bot-work

# Codex実行時に追加するシステムプロンプト（オプション）
# Codexの動作をカスタマイズしたい場合に使用
# CODEX_APPEND_SYSTEM_PROMPT="あなたは日本語で応答します"
